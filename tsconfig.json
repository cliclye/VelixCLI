{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "paths": {
      "@/*": ["./src/velix-sdk/*"],
      "@tui/*": ["./cli/cmd/tui/*"],
      "@velix-ai/sdk/v2": ["./src/velix-sdk/velix-sdk-v2.ts"],
      "@velix-ai/sdk": ["./src/velix-sdk/velix-sdk.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/tui-main.tsx"]
}
