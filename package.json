    "conf": "^12.0.0",
    "fuzzysort": "^3.1.0",
    "inquirer": "^9.2.12",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0",
    "node-pty": "^1.0.0",
    "open": "^11.0.0",
    "opentui-spinner": "^0.0.6",
    "ora": "^8.0.1",
